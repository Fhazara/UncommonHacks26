{
  "name": "judge-agent",
  "publisher": "hci-research",
  "displayName": "Judge Agent",
  "description": "HCI experiment judge agent for telemetry collection and participant interaction",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "judgeSidebarChat",
          "name": "Judge Agent",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  }
}
